{
  "expo": {
    "name": "Selfplace",
    "slug": "Selfplace",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "selfplace",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.silmo.Selfplace",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.silmo.Selfplace",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#A5AD94",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#A5AD94",
          "dark": {
            "backgroundColor": "#A5AD94"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-notifications",
      "expo-web-browser",
      "react-native-iap"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8cfcc848-c3f8-4fb6-a4b7-649d92fdaa89"
      }
    },
    "owner": "silmo"
  }
}
